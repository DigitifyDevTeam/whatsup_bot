TEAMWORK_API_KEY=
TEAMWORK_PROJECT_ID=
TEAMWORK_DOMAIN=yourcompany.teamwork.com
TEAMWORK_TASKLIST_NAME=Ai_test

LLAMA_ENDPOINT=http://localhost:11434
LLAMA_MODEL=llama3.1:8b
# Per-request read timeout for Ollama /api/chat (seconds). CPU hosts often need 600+.
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_CONNECT_TIMEOUT_SECONDS=10
# 0 = unload model from RAM/VRAM right after each chat (saves memory; slower next call).
OLLAMA_KEEP_ALIVE=0
# Per-request warm window for translate + extract (does not change model/prompts).
OLLAMA_PIPELINE_KEEP_ALIVE=2m
# Deterministic JSON task extraction (0 = default; does not affect translation calls).
OLLAMA_TEMPERATURE=0

WHISPER_MODEL_SIZE=base
# true = load Whisper only for each voice job, then free RAM (slower repeat voice notes).
# false = keep model in memory after first use (faster if you get many voice messages).
WHISPER_UNLOAD_AFTER_TRANSCRIBE=true
WHISPER_LANGUAGE=fr
WHISPER_PREPROCESS_AUDIO=true
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
# Skip Ollama translation when Whisper detected French above this confidence (same transcription).
SKIP_FRENCH_TRANSLATION_IF_DETECTED_FR=true
SKIP_FRENCH_TRANSLATION_MIN_PROB=0.85
## Force voice-note output language (currently supports French translation via Ollama)
AUDIO_OUTPUT_LANGUAGE=fr
WHISPER_ONLY=false
FALLBACK_TO_TRANSCRIPT_ON_AI_ERROR=true
TRANSCRIPT_LOG_PATH=logs/transcripts.jsonl
TASK_OUTPUT_LOG_PATH=logs/tasks_output.jsonl
SKIP_TEAMWORK=false
