TEAMWORK_API_KEY=
TEAMWORK_PROJECT_ID=
TEAMWORK_DOMAIN=yourcompany.teamwork.com
TEAMWORK_TASKLIST_NAME=Ai_test

LLAMA_ENDPOINT=http://localhost:11434
LLAMA_MODEL=llama3.1:8b

WHISPER_MODEL_SIZE=base
WHISPER_LANGUAGE=fr
WHISPER_PREPROCESS_AUDIO=true
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
## Force voice-note output language (currently supports French translation via Ollama)
AUDIO_OUTPUT_LANGUAGE=fr
WHISPER_ONLY=false
FALLBACK_TO_TRANSCRIPT_ON_AI_ERROR=true
TRANSCRIPT_LOG_PATH=logs/transcripts.jsonl
TASK_OUTPUT_LOG_PATH=logs/tasks_output.jsonl
SKIP_TEAMWORK=false
